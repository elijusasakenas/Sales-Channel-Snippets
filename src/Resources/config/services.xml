<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>
        <defaults autowire="true" autoconfigure="true"/>

        <service id="SalesChannelSnippets\Core\Content\SalesChannelSnippet\SalesChannelSnippetDefinition">
            <tag name="shopware.entity.definition"/>
        </service>

        <service id="SalesChannelSnippets\Translation\SalesChannelSnippetTranslator" decorates="translator">
            <argument type="service" id="SalesChannelSnippets\Translation\SalesChannelSnippetTranslator.inner"/>
            <argument type="service" id="Doctrine\DBAL\Connection"/>
            <argument type="service" id="request_stack"/>
        </service>

        <service id="SalesChannelSnippets\Subscriber\SalesChannelSnippetCacheInvalidationSubscriber"/>
    </services>
</container>
