<sw-page class="sales-channel-snippet-list">
    <template #smart-bar-header>
        <h2>{{ $tc('sales-channel-snippets.general.mainMenuItemGeneral') }}</h2>
    </template>

    <template #smart-bar-actions>
        <sw-button
            :disabled="!canEdit"
            @click="addSnippet">
            {{ $tc('sales-channel-snippets.actions.add') }}
        </sw-button>

        <sw-button-process
            :isLoading="isLoading"
            :processSuccess="processSuccess"
            :disabled="!canEdit"
            @process-finish="saveFinish"
            @click="onSave">
            {{ $tc('sales-channel-snippets.actions.save') }}
        </sw-button-process>
    </template>

    <template #content>
        <sw-card-view>
            <sw-card :title="$tc('sales-channel-snippets.cards.assignment')">
                <div class="sales-channel-snippet-list__filters">
                    <sw-entity-single-select
                        v-model:value="filters.salesChannelId"
                        entity="sales_channel"
                        required
                        :label="$tc('sales-channel-snippets.fields.salesChannel')"
                        @update:value="onFilterChange" />

                    <sw-entity-single-select
                        v-model:value="filters.languageId"
                        entity="language"
                        required
                        :label="$tc('sales-channel-snippets.fields.language')"
                        @update:value="onFilterChange" />
                </div>
            </sw-card>

            <sw-card :title="$tc('sales-channel-snippets.cards.snippets')">
                <div
                    v-if="!canEdit"
                    class="sales-channel-snippet-list__notice">
                    <strong>{{ $tc('sales-channel-snippets.empty.selectTitle') }}</strong>
                    <span>{{ $tc('sales-channel-snippets.empty.selectSubline') }}</span>
                </div>

                <div
                    v-else-if="isLoading"
                    class="sales-channel-snippet-list__loader">
                    <sw-loader />
                </div>

                <div
                    v-else-if="loadError"
                    class="sales-channel-snippet-list__notice sales-channel-snippet-list__notice--error">
                    <strong>{{ $tc('sales-channel-snippets.empty.loadErrorTitle') }}</strong>
                    <span>{{ $tc('sales-channel-snippets.empty.loadErrorSubline') }}</span>
                </div>

                <div
                    v-else
                    class="sales-channel-snippet-list__rows">
                    <div class="sales-channel-snippet-list__search">
                        <sw-text-field
                            v-model:value="snippetSearchTerm"
                            :label="$tc('sales-channel-snippets.fields.searchExisting')"
                            :placeholder="$tc('sales-channel-snippets.placeholders.searchExisting')"
                            @keyup.enter="searchExistingSnippets" />

                        <sw-button
                            :disabled="isSnippetSearchLoading || !snippetSearchTerm"
                            @click="searchExistingSnippets">
                            {{ $tc('sales-channel-snippets.actions.search') }}
                        </sw-button>
                    </div>

                    <div
                        v-if="isSnippetSearchLoading"
                        class="sales-channel-snippet-list__search-loader">
                        <sw-loader />
                    </div>

                    <div
                        v-else-if="snippetSearchResults.length > 0"
                        class="sales-channel-snippet-list__results">
                        <div
                            v-for="result in snippetSearchResults"
                            :key="result.translationKey + result.locale"
                            class="sales-channel-snippet-list__result">
                            <div class="sales-channel-snippet-list__result-text">
                                <strong>{{ result.translationKey }}</strong>
                                <span>{{ result.value }}</span>
                                <small>{{ result.snippetSetName }} - {{ result.locale }}</small>
                            </div>

                            <sw-button
                                size="small"
                                @click="useExistingSnippet(result)">
                                {{ $tc('sales-channel-snippets.actions.use') }}
                            </sw-button>
                        </div>
                    </div>

                    <div
                        v-else-if="hasSnippetSearchRun"
                        class="sales-channel-snippet-list__notice">
                        <strong>{{ $tc('sales-channel-snippets.empty.noSearchResultsTitle') }}</strong>
                        <span>{{ $tc('sales-channel-snippets.empty.noSearchResultsSubline') }}</span>
                    </div>

                    <div
                        v-for="snippet in snippets"
                        :key="snippet.id || snippet._uniqueIdentifier"
                        class="sales-channel-snippet-list__row">
                        <sw-text-field
                            v-model:value="snippet.translationKey"
                            required
                            :label="$tc('sales-channel-snippets.fields.key')"
                            :placeholder="$tc('sales-channel-snippets.placeholders.key')" />

                        <sw-textarea-field
                            v-model:value="snippet.value"
                            required
                            :label="$tc('sales-channel-snippets.fields.value')" />

                        <sw-button
                            variant="danger"
                            @click="removeSnippet(snippet)">
                            {{ $tc('sales-channel-snippets.actions.remove') }}
                        </sw-button>
                    </div>

                    <div
                        v-if="snippets.length === 0"
                        class="sales-channel-snippet-list__notice">
                        <strong>{{ $tc('sales-channel-snippets.empty.noSnippetsTitle') }}</strong>
                        <span>{{ $tc('sales-channel-snippets.empty.noSnippetsSubline') }}</span>
                    </div>
                </div>
            </sw-card>
        </sw-card-view>
    </template>
</sw-page>
